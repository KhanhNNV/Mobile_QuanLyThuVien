<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/ivBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/baseline_arrow_back_24"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/tvHeaderTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvHeaderTitle" />


    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/tvHeaderTitle"
        android:textColor="#212121"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/ivBack"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/tvHeaderSubtitle"
        android:textColor="@color/gray"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="@+id/tvHeaderTitle"

        app:layout_constraintTop_toBottomOf="@+id/tvHeaderTitle" />


    <ImageView
        android:id="@+id/ivEdit"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:clickable="true"
        android:focusable="true"
        android:padding="12dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="@color/blue"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/btnBell"
        app:layout_constraintEnd_toStartOf="@+id/btnBell"
        app:layout_constraintTop_toTopOf="@+id/btnBell" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/btnBell"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardBackgroundColor="@color/gray"
        app:cardCornerRadius="14dp"
        android:layout_marginEnd="8dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="@+id/tvHeaderSubtitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvHeaderTitle">

        <ImageView
            android:id="@+id/ivHeaderIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_popup_reminder"
            app:tint="@color/gray" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvNotificationBadge"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/red"
            app:cardCornerRadius="5dp"
            app:cardElevation="0dp"
            android:visibility="visible"/> <!-- invisible để tắt -->

    </com.google.android.material.card.MaterialCardView>

    <View
        android:id="@+id/vDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvHeaderSubtitle"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="0dp" />


</androidx.constraintlayout.widget.ConstraintLayout>