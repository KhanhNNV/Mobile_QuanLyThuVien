<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Lập trình Java"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/ibtSet"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/ibtSet"
            android:layout_width="20dp"
            android:layout_height="24dp"
            android:backgroundTint="@color/bg_card"
            android:contentDescription="Tùy chọn sách"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:srcCompat="@drawable/ic_3_dots" />

        <TextView
            android:id="@+id/tvAuthorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Tác giả:"
            android:textColor="@color/chip_primary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTitle" />

        <TextView
            android:id="@+id/tvAuthor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="James Gosling"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvAuthorTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvAuthorTitle"
            app:layout_constraintTop_toTopOf="@+id/tvAuthorTitle" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierAuthor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tvAuthorTitle,tvAuthor" />

        <TextView
            android:id="@+id/tvCategoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_secondary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Thể loại:"
            android:textColor="@color/chip_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierAuthor" />

        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Kỹ thuật"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvCategoryTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvCategoryTitle"
            app:layout_constraintTop_toTopOf="@+id/tvCategoryTitle" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tvCategoryTitle,tvCategory" />

        <TextView
            android:id="@+id/tvBarcodeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_secondary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Mã sách:"
            android:textColor="@color/chip_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierCategory" />

        <TextView
            android:id="@+id/tvBarcode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="CPY-10023"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvBarcodeTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tvBarcodeTitle"
            app:layout_constraintTop_toTopOf="@+id/tvBarcodeTitle" />

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrierBarcode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="tvBarcodeTitle,tvBarcode" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:alpha="0.2"
            android:background="@color/text_tertiary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/barrierBarcode" />

        <TextView
            android:id="@+id/tvDetailStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_status_info"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Đang mượn"
            android:textColor="@color/text_status_info"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvReturnDateTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_chip_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Ngày trả:"
            android:textColor="@color/chip_primary"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <TextView
            android:id="@+id/tvReturnDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:text="20/05/2026"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvReturnDateTitle"
            app:layout_constraintEnd_toStartOf="@+id/tvDetailStatus"
            app:layout_constraintStart_toEndOf="@+id/tvReturnDateTitle"
            app:layout_constraintTop_toTopOf="@+id/tvReturnDateTitle" />

        <TextView
            android:id="@+id/tvDetailDueDateTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/bg_chip_secondary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Hạn trả:"
            android:textColor="@color/chip_secondary"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvReturnDateTitle" />

        <TextView
            android:id="@+id/tvDetailDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="20/06/2026"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvDetailDueDateTitle"
            app:layout_constraintStart_toEndOf="@+id/tvDetailDueDateTitle"
            app:layout_constraintTop_toTopOf="@+id/tvDetailDueDateTitle" />

        <ImageView
            android:id="@+id/ivWarningOverdueDetail"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_diamond_exclamation"
            app:tint="@color/text_status_error"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/tvDetailDueDate"
            app:layout_constraintStart_toEndOf="@+id/tvDetailDueDate"
            app:layout_constraintTop_toTopOf="@+id/tvDetailDueDate" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>