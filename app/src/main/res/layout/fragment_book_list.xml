<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Top Content Container -->
    <LinearLayout
        android:id="@+id/llTopContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/recyclerViewBooks"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvPageTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kho sách"
                    android:textColor="@color/text_primary"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvBookStats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đang tải..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnAddBook"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="＋ Nhập"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:backgroundTint="@color/accent_blue"
                android:paddingHorizontal="18dp"
                app:cornerRadius="20dp" />

        </LinearLayout>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_search"
                app:tint="@color/text_hint" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Tìm tên sách, ISBN, tác giả..."
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="10dp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

        </LinearLayout>

        <!-- Filter Chips -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="20dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả"
                    android:checked="true"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/accent_blue"
                    app:chipStrokeWidth="0dp"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLow"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sắp hết"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/divider"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOut"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hết kho"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/divider"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipLost"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mất/Hỏng"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    app:chipBackgroundColor="@color/bg_card"
                    app:chipStrokeWidth="1dp"
                    app:chipStrokeColor="@color/divider"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Book List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewBooks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/llTopContent"
        app:layout_constraintBottom_toTopOf="@id/bottomActionContainer"
        android:clipToPadding="false"
        android:paddingVertical="8dp"
        android:paddingHorizontal="16dp" />

    <!-- Sticky Bottom action bar -->
    <LinearLayout
        android:id="@+id/bottomActionContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_dark"
        android:paddingHorizontal="20dp"
        android:paddingVertical="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:gravity="center">

        <!-- Lập phiếu Button -->
        <LinearLayout
            android:id="@+id/btnCreateTicket"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_receipt"
                app:tint="@color/text_primary"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lập phiếu"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <!-- Xác nhận trả Button -->
        <LinearLayout
            android:id="@+id/btnConfirmReturn"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_blue"
            android:backgroundTint="@color/accent_blue"
            android:gravity="center"
            android:orientation="horizontal"
            android:layout_marginStart="8dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận trả"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>