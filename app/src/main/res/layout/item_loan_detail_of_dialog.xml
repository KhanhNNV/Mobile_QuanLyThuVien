<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/bg_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:text="Truyện ngắn"
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/ibtSet"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_circle_3_dots"
                app:tint="@color/chip_primary"
                android:contentDescription="Tùy chọn sách" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvAuthorTitle"
                android:text="@string/tacGia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/chip_primary"
                android:background="@color/bg_chip_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvAuthor"
                android:text="Kim Đồng"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:text="•"
                android:textColor="@color/text_secondary"/>
            <TextView
                android:id="@+id/tvCatetoryTitle"
                android:text="@string/theLoai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/chip_primary"
                android:background="@color/bg_chip_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvCatetory"
                android:text="tiểu thuyết"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/text_tertiary"
            android:alpha="0.2"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNgayTra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ngayTra"
                android:textColor="@color/chip_primary"
                android:background="@color/bg_chip_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvReturnDate"
                android:text="25/3/2026"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvDetailStatus"
                android:text="Đang mượn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_rounded"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textColor="@color/text_status_info"
                android:backgroundTint="@color/status_info"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>