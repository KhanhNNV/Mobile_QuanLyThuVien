<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvAvatar"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_status"
            android:gravity="center"
            android:text="NV"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReaderName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:text="Nguyễn Văn A"
            android:textColor="#BAB7B7"
            android:textSize="16dp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@+id/tvAvatar"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvReaderInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="DG-00241 · 0901 234 567"
            android:textColor="@color/text_tertiary"
            app:layout_constraintStart_toStartOf="@+id/tvReaderName"
            app:layout_constraintTop_toBottomOf="@+id/tvReaderName" />

        <TextView
            android:id="@+id/tvReaderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="50dp"
            android:background="@drawable/bg_status"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Đang mượn"
            android:textColor="@color/brand_success"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvReaderName" />

        <TextView
            android:id="@+id/tvMoreOptions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/ic_more_vert"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvBorrowedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/bg_main"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Tổng sách mượn:"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvAvatar" />

        <TextView
            android:id="@+id/tvBorrowedValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="03 cuốn"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvBorrowedLabel"
            app:layout_constraintStart_toEndOf="@+id/tvBorrowedLabel"
            app:layout_constraintTop_toTopOf="@+id/tvBorrowedLabel"
            app:layout_constraintVertical_bias="0.52" />

        <TextView
            android:id="@+id/tvDebtLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/bg_main"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Nợ:"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toEndOf="@+id/tvBorrowedValue"
            app:layout_constraintTop_toBottomOf="@+id/tvAvatar" />

        <TextView
            android:id="@+id/tvDebtValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="200.000"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvDebtLabel"
            app:layout_constraintStart_toEndOf="@+id/tvDebtLabel"
            app:layout_constraintTop_toTopOf="@+id/tvDebtLabel"
            app:layout_constraintVertical_bias="0.52" />

        <TextView
            android:id="@+id/tvDebtCurrency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="5dp"
            android:text="VND"
            android:textColor="@color/text_primary"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvDebtValue"
            app:layout_constraintStart_toEndOf="@+id/tvDebtValue"
            app:layout_constraintTop_toTopOf="@+id/tvDebtValue"
            app:layout_constraintVertical_bias="0.52" />

        <TextView
            android:id="@+id/btnViewHistory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_status"
            android:gravity="center"
            android:padding="5dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Lịch sử"
            android:textColor="@color/brand_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvBorrowedLabel"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toEndOf="@+id/tvDebtCurrency"
            app:layout_constraintTop_toTopOf="@+id/tvBorrowedLabel"
            app:layout_constraintVertical_bias="0.851" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>