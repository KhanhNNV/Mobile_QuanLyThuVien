<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/bg_card">

    <include
        android:id="@+id/headerDashboard"
        layout="@layout/layout_custom_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <AutoCompleteTextView
            android:id="@+id/autoSearchStaff"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="6dp"
            android:hint="@string/hint_staff"
            android:inputType="text"
            android:maxLines="1"
            android:padding="10dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_tertiary" />

        <Spinner
            android:id="@+id/spnStatusFilter"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="140dp"
            android:background="@drawable/bg_search"
            android:paddingHorizontal="12dp"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewStaff"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:background="@color/bg_card"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="80dp" />
    <include layout="@layout/layout_fab_staff" />

</LinearLayout>