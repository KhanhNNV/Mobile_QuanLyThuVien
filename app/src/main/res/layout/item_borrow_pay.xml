<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Nguyễn Văn A"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvLoanStatus"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvLoanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/status_info"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Đang mượn"
            android:textColor="@color/text_status_info"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@+id/tvName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/tvName" />

        <TextView
            android:id="@+id/tvMa"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/bg_chip_primary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="@string/loanId"
            android:textColor="@color/chip_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvName" />

        <TextView
            android:id="@+id/tvLoanId"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="RV01"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvMa"
            app:layout_constraintEnd_toStartOf="@+id/tvLoanStatus"
            app:layout_constraintStart_toEndOf="@+id/tvMa"
            app:layout_constraintTop_toTopOf="@+id/tvMa" />

        <TextView
            android:id="@+id/tvTitleDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_status"
            android:backgroundTint="@color/bg_chip_secondary"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="@string/dueDate"
            android:textColor="@color/chip_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvMa" />

        <TextView
            android:id="@+id/tvDueDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="20/06/2026"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            app:layout_constraintBottom_toBottomOf="@+id/tvTitleDate"
            app:layout_constraintStart_toEndOf="@+id/tvTitleDate"
            app:layout_constraintTop_toTopOf="@+id/tvTitleDate" />

        <ImageView
            android:id="@+id/ivWarningOverdue"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginStart="6dp"
            android:src="@drawable/ic_diamond_exclamation"
            app:tint="@color/text_status_error"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@+id/tvDueDate"
            app:layout_constraintStart_toEndOf="@+id/tvDueDate"
            app:layout_constraintTop_toTopOf="@+id/tvDueDate" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>