<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pm1"
            android:textSize="28sp"
            android:gravity="center"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pm2"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"> <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/edtLoanReaderId"
            android:inputType="textCapCharacters"
            android:hint="@string/pm3"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/tvReaderName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tên độc giả: [Chờ nhập mã...]"
            android:textColor="@color/btn_primary"
            android:textStyle="italic"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"/>
        <TextView
            android:id="@+id/tvReaderViolation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cảnh báo: Đang có vi phạm chưa xử lý!"
            android:textColor="@color/red"
            android:textStyle="bold|italic"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginStart="4dp"
            android:visibility="gone"
            tools:visibility="visible" />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pm8"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <AutoCompleteTextView
                android:id="@+id/autoSearchBook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Gõ để tìm mã hoặc tên sách..."
                android:completionThreshold="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSelectedBooks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_selected_book"/>
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelLoan"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/pm10"
                android:textColor="@color/text_secondary"
                app:strokeColor="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveLoan"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/pm11"
                android:textColor="@color/white"
                app:backgroundTint="@color/btn_primary" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>